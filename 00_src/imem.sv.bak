module imem( input    wire    \[31:0\] i\_imem\_addr, output   wire    \[31:0\] o\_imem\_data );

```
reg \[31:0\] memory\[100 - 1 : 0\]; // 2048  
  
initial begin   
      
   // $readmemh("../02\_test/dump/isa\_4b.hex", memory);  
  
end  
  
// Su dung i\_imem\_addr de truy cap o nho (Word-aligned address)  
assign o\_imem\_data = memory\[i\_imem\_addr\[13:2\]\];
```

endmodule

